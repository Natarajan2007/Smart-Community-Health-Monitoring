# ============================================
# Environment Configuration Template
# ============================================
# Copy this file to .env.local and fill in your values
# Never commit .env or .env.local to version control
#
# Server Configuration
# ============================================

# Port on which the Express server will run
# Default: 5000 for development, use 80/443 for production
PORT=5000

# Application environment
# Values: development | staging | production
NODE_ENV=development

# Enable debug logs (verbose request/response logging)
# Set to 'true' for development, 'false' for production
DEBUG=false

# ============================================
# OpenAI API Configuration
# ============================================

# OpenAI API Key - Get from https://platform.openai.com/api-keys
# Required for Chat functionality
# Keep this secret - never commit this to repository!
VITE_OPENAI_API_KEY=sk_your_api_key_here

# OpenAI Model selection
# Recommended: gpt-4-turbo-preview or gpt-3.5-turbo
# Default: gpt-3.5-turbo (cheaper, faster)
VITE_OPENAI_MODEL=gpt-3.5-turbo

# Maximum tokens for API responses
# Controls response length. Lower = cheaper & faster, Higher = more detailed
# Range: 256-4096. Default: 2048
VITE_OPENAI_MAX_TOKENS=2048

# ============================================
# CORS Configuration
# ============================================

# Allowed origins for cross-origin requests
# For development: http://localhost:3000,http://localhost:5000
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ============================================
# Rate Limiting Configuration
# ============================================

# Rate limit: requests per time window (in seconds)
# Default: 10 requests per 60 seconds per IP
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# ============================================
# API Request Configuration
# ============================================

# Request timeout in milliseconds (default: 30000 = 30 seconds)
REQUEST_TIMEOUT=30000

# Maximum payload size for requests (default: 1mb)
MAX_REQUEST_SIZE=1mb

# Maximum conversation history to maintain (default: 10)
MAX_HISTORY_LENGTH=10

# ============================================
# Logging Configuration
# ============================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Enable request logging middleware
ENABLE_REQUEST_LOGGING=true

# ============================================
# Performance Configuration
# ============================================

# Enable caching for frequently requested data
ENABLE_CACHING=true

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# ============================================
# Frontend Development
# ============================================

# Vite development server port
VITE_PORT=3000

# API endpoint for backend calls
VITE_API_URL=http://localhost:5000

# Enable source maps for debugging
VITE_SOURCE_MAP=true

# ============================================
# Feature Flags
# ============================================

# Enable analytics dashboard
ENABLE_ANALYTICS=true

# Enable eligibility checker feature
ENABLE_ELIGIBILITY_CHECKER=true

# Enable gamified quiz
ENABLE_QUIZ=true

# Enable chat widget
ENABLE_CHAT=true

# ============================================
# Security Configuration
# ============================================

# Enable security headers (helmet.js)
ENABLE_SECURITY_HEADERS=true

# Enable Content Security Policy
ENABLE_CSP=true

# Session secret for sessions
SESSION_SECRET=your_secure_random_string_here
