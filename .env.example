# ============================================
# Environment Configuration Template
# ============================================
# Copy this file to .env.local and fill in your values
# Never commit .env or .env.local to version control
# Run 'npm install' FIRST, then copy this file to .env.local
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Update values below with your credentials
# 3. Start server with: npm run server
# 4. Start frontend with: npm run dev (in another terminal)

# ============================================
# SERVER CONFIGURATION
# ============================================

# Port on which Express server will run
# Development: 5000
# Production: 80 or 443 (with reverse proxy)
PORT=5000

# Application environment
# Values: development | staging | production
# Controls logging level, error handling verbosity, and cache behavior
NODE_ENV=development

# Enable verbose debug logging
# 'true' - logs all requests/responses and detailed error info
# 'false' - production-safe logging only
DEBUG=false

# ============================================
# OpenAI API CONFIGURATION (REQUIRED)
# ============================================

# OpenAI API Key for chat functionality
# Get from: https://platform.openai.com/api-keys
# Format: sk-xxxxxxxxxxxx (starts with 'sk-')
# REQUIRED - Chat will not work without this
# ⚠️ NEVER commit this to version control
VITE_OPENAI_API_KEY=sk_your_api_key_here

# OpenAI Model selection
# Options: gpt-3.5-turbo | gpt-4 | gpt-4-turbo-preview | gpt-4-turbo
# Recommendations:
#   - gpt-3.5-turbo: Fastest & cheapest (recommended for production)
#   - gpt-4-turbo: More capable, higher cost
# Default: gpt-3.5-turbo
VITE_OPENAI_MODEL=gpt-3.5-turbo

# Maximum tokens for OpenAI API responses
# Tokens ≈ 4 characters
# Range: 256-4096
# Lower = cheaper & faster responses
# Higher = more detailed answers
# Default: 2048 (recommended)
VITE_OPENAI_MAX_TOKENS=2048

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origins for cross-origin requests (comma-separated)
# Development: http://localhost:3000,http://localhost:5000
# Production: https://yourdomain.com,https://www.yourdomain.com
# Add multiple origins separated by commas (no spaces)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================

# Rate limit: allowed requests per time window
# Default: 10 requests
RATE_LIMIT_REQUESTS=10

# Time window in seconds for rate limit
# Default: 60 seconds
# Example: 10 requests per 60 seconds per IP
RATE_LIMIT_WINDOW=60

# ============================================
# REQUEST/RESPONSE CONFIGURATION
# ============================================

# Request timeout in milliseconds
# Default: 30000 (30 seconds)
# Increase if experiencing "504 Gateway Timeout" errors
# Max recommended: 60000 (1 minute)
REQUEST_TIMEOUT=30000

# Maximum payload size for incoming requests
# Default: 1mb
# Values: '1mb', '2mb', '5mb', etc.
MAX_REQUEST_SIZE=1mb

# Maximum conversation history messages to maintain
# Reduces token usage and improves performance
# Default: 10
# Range: 1-50
MAX_HISTORY_LENGTH=10

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level for server logging
# Options: debug | info | warn | error
# debug = most verbose, error = only errors
# Development: debug or info
# Production: info or warn
LOG_LEVEL=info

# Enable detailed request/response logging
# 'true' - logs all HTTP requests and responses
# 'false' - minimal logging
ENABLE_REQUEST_LOGGING=true

# ============================================
# CACHING CONFIGURATION
# ============================================

# Enable response caching for frequent queries
# 'true' - improves performance
# 'false' - always fetch fresh data
ENABLE_CACHING=true

# Cache time-to-live in seconds
# Default: 3600 (1 hour)
# Set to 0 to disable cache
CACHE_TTL=3600

# ============================================
# FRONTEND DEVELOPMENT
# ============================================

# Vite development server port
# Default: 3000
# Change if 3000 is already in use
VITE_PORT=3000

# Backend API URL for frontend requests
# Development: http://localhost:5000
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:5000

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Application name (displayed in header/browser)
# Default: Aadhaar & DBT Awareness Platform
VITE_APP_NAME=Aadhaar & DBT Awareness Platform

# ============================================
# QUICK START
# ============================================
# 1. fill in VITE_OPENAI_API_KEY above
# 2. Run: npm run server (terminal 1)
# 3. Run: npm run dev (terminal 2)
# 4. Open: http://localhost:3000
#
# For more help, see README.md
# ============================================

# Enable source maps for debugging
VITE_SOURCE_MAP=true

# ============================================
# Feature Flags
# ============================================

# Enable analytics dashboard
ENABLE_ANALYTICS=true

# Enable eligibility checker feature
ENABLE_ELIGIBILITY_CHECKER=true

# Enable gamified quiz
ENABLE_QUIZ=true

# Enable chat widget
ENABLE_CHAT=true

# ============================================
# Security Configuration
# ============================================

# Enable security headers (helmet.js)
ENABLE_SECURITY_HEADERS=true

# Enable Content Security Policy
ENABLE_CSP=true

# Session secret for sessions
SESSION_SECRET=your_secure_random_string_here
